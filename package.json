    "@mui/x-charts": "^9.0.2",
    "@mui/x-date-pickers": "^9.0.2",
    "@react-leaflet/core": "^3.0.0",
    "@react-pdf/renderer": "^4.5.1",
    "@serwist/next": "^9.5.7",
    "@turf/bbox-polygon": "^7.3.5",
    "@turf/boolean-within": "^7.3.5",
