    "leaflet.markercluster": "^1.5.3",
    "lodash.debounce": "^4.0.8",
    "marked": "^18.0.2",
    "mathjs": "^15.2.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "mui-color-input": "^8.0.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "proj4": "^2.20.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "19.2.5",
    "react-firebase-hooks": "^5.1.1",
    "react-google-one-tap-login": "^0.1.1",
    "react-leaflet": "^5.0.0",
