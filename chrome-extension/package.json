{
  "name": "einsatzkarte-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt prepare && tsc --noEmit && wxt build",
    "build:prod": "wxt prepare && tsc --noEmit && EXT_ENV_LOCAL=1 wxt build && node scripts/package.mjs",
    "test": "wxt prepare && vitest run",
    "postinstall": "wxt prepare",
    "publish:cws": "npm run build:prod && node scripts/publish-cws.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "firebase": "12.11.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.304",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@wxt-dev/module-react": "^1.2.2",
    "chrome-webstore-upload": "^4.0.3",
    "crx3": "^2.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wxt": "^0.20.25"
  },
  "overrides": {
    "typescript-eslint": "8.59.0"
  }
}
