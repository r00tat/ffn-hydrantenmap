{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "types": ["chrome"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [".wxt/**/*", "entrypoints/**/*", "src/**/*", "wxt.config.ts"],
  "exclude": ["dist", "node_modules"]
}
